{
  "name": "carbon-diary",
  "version": "1.0.0",
  "description": "Carbon Diary — Daily carbon footprint journal",
  "scripts": {
    "test": "jest --coverage --verbose",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage --ci"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": ["js/**/*.js"]
  }
}
